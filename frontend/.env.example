# Copy to `.env` or `.env.local` for Vite (`npm run dev`).
#
# --- Same-origin dev (recommended): browser → Vite → proxy → gateway ---
# Leave VITE_API_URL unset. Set the gateway URL for the dev proxy only:
VITE_PROXY_TARGET=http://localhost:11001
#
# --- Cross-origin dev: browser calls gateway directly ---
# VITE_API_URL=http://localhost:11001
# Then set FRONTEND_ORIGIN in docker-compose / .env to match this dev server, e.g. http://localhost:5173

# Optional: dev server port (default 3000 in vite.config)
# VITE_DEV_PORT=3000
