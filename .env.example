# ===========================
# ShopVerse Microservices
# Environment Configuration
# ===========================

# ===== MySQL =====
MYSQL_ROOT_PASSWORD=rootpassword
DB_USER=shopverse
DB_PASSWORD=shopverse123

# ===== JWT =====
JWT_SECRET=local-dev-jwt-secret-key-change-in-production
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

# ===== Admin bootstrap (auth-service) =====
ADMIN_SEED_EMAIL=admin@shopverse.local
ADMIN_SEED_PASSWORD=ChangeMe!Admin123

# ===== Redis =====
REDIS_PASSWORD=redis-dev-password

# ===== Service Ports (host-side, starting at 11100 to avoid conflicts) =====
FRONTEND_PORT=11100
GATEWAY_PORT=11101
AUTH_PORT=11102
PRODUCT_PORT=11103
CART_PORT=11104
ORDER_PORT=11105
USER_PORT=11106
NOTIFICATION_PORT=11107
MYSQL_PORT=11108
REDIS_PORT=11109

# ===== CORS (Fiber services) =====
# Required when the *browser* calls the gateway on a different origin than this value
# (e.g. VITE_API_URL=http://localhost:11101 while the SPA is on http://localhost:5173).
# Dockerized SPA on Nginx using relative /api (same host:port as the page) does NOT need CORS.
FRONTEND_ORIGIN=http://localhost:11100
# Vite dev (typical):
# FRONTEND_ORIGIN=http://localhost:3000

# ===== Vite (see frontend/.env.example) =====
# Docker *image* build: leave build-arg VITE_API_URL empty so axios uses relative `/api`
# and container Nginx proxies to api-gateway.
# Host `npm run dev`: use `frontend/.env` with VITE_PROXY_TARGET=http://localhost:<GATEWAY_PORT>
# or set VITE_API_URL=http://localhost:<GATEWAY_PORT> and FRONTEND_ORIGIN to your dev origin.
